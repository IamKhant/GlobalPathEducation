# Local default. Set the deployed backend URL in your hosting platform env settings.
VITE_API_BASE_URL="http://localhost:3000"

# Production example:
# VITE_API_BASE_URL="https://your-backend.onrender.com"
VITE_CLERK_PUBLISHABLE_KEY="pk_test_your_key_here"

# Optional. Frankfurter public API does not require an API key.
# Change this only if you self-host Frankfurter later.
VITE_FRANKFURTER_API_URL="https://api.frankfurter.dev"
