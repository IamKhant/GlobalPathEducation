# `DIRECT_URL` is preferred by the current backend setup.
# If `DIRECT_URL` is missing, the server now falls back to `DATABASE_URL`.
DIRECT_URL="postgresql://user:password@host:5432/database"
DATABASE_URL="postgresql://user:password@host:5432/database"

# Local default. Set your deployed frontend URL in Render or your host.
FRONTEND_URL="http://localhost:5173"

# Production example:
# FRONTEND_URL="https://your-frontend.vercel.app"
CLERK_SECRET_KEY="sk_test_your_key_here"

# DeepL stays backend-only. Never add this to frontend/.env.
DEEPL_API_KEY="your_deepl_key_here"
DEEPL_API_URL="https://api-free.deepl.com/v2"
